# --- Browser (Vite) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: if the mail API runs on another origin in production
# VITE_API_URL=

# --- API server (server/index.mjs) — same values as Vite, plus Resend ---
# Copy from Supabase Settings → API (or duplicate VITE_* as below for Node)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified domain in Resend, or Resend sandbox: Runway <onboarding@resend.dev>
RESEND_FROM=Runway <onboarding@resend.dev>
# PORT=8787
